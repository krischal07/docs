    {
      "name": "Partner API",
      "item": [
        {
          "name": "Connect Restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('connect returns 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('connect success flag is true', function () { pm.expect(body.success).to.eql(true); });",
                  "pm.test('connect message matches implementation', function () { pm.expect(body.message).to.eql('POS connected'); });",
                  "pm.test('status is CONNECTED after connect', function () { pm.expect(body.status).to.eql('CONNECTED'); });",
                  "pm.test('token is returned', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });",
                  "pm.test('restaurantId is returned', function () { pm.expect(body.restaurantId).to.eql(pm.collectionVariables.get('expectedRestaurantId')); });",
                  "pm.test('external location matches expected restaurant', function () { pm.expect(body.externalLocationId).to.eql(pm.collectionVariables.get('expectedRestaurantId')); });",
                  "pm.collectionVariables.set('token', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-partner-key",
                "value": "{{partnerKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"restaurantId\": \"{{expectedRestaurantId}}\",\n  \"restaurantName\": \"{{expectedRestaurantName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/{provider}/connect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "partners",
                "pos",
                "connect"
              ]
            },
            "description": "Primary partner-facing connect request using the singular POS binding contract."
          }
        },
        {
          "name": "Submit Test Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('submit test sale returns 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('outer success flag is true', function () { pm.expect(body.success).to.eql(true); });",
                  "pm.test('outer message matches implementation', function () { pm.expect(body.message).to.eql('Test sale submitted'); });",
                  "pm.test('inner webhook success flag is true', function () { pm.expect(body.data && body.data.success).to.eql(true); });",
                  "pm.test('inner webhook message matches implementation', function () { pm.expect(['Event received', 'Event already processed']).to.include(body.data && body.data.message); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-partner-key",
                "value": "{{partnerKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"payload\": {\n    \"event_type\": \"order.completed\",\n    \"order_id\": \"pos-sale-1001\",\n    \"created_at\": \"2026-06-08T10:15:00.000Z\",\n    \"amount\": 850,\n    \"currency\": \"NPR\",\n    \"customer\": {\n      \"phone\": \"{{customerPhone}}\"\n    },\n    \"items\": [\n      {\n        \"name\": \"Cappuccino\",\n        \"qty\": 1,\n        \"price\": 850\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/{provider}/test-sale",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "partners",
                "pos",
                "test-sale"
              ]
            },
            "description": "Optional partner-side shortcut for submitting the first valid sale into the webhook pipeline."
          }
        },
