    {
      "name": "Customer API",
      "item": [
        {
          "name": "Search Customer After Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('customer search succeeds', () => { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('response contains exists flag', () => { pm.expect(body.exists).to.eql(true); });",
                  "pm.test('response contains customer data', () => { pm.expect(body.customer).to.be.an('object'); });",
                  "const customer = body.customer;",
                  "pm.test('phone matches sale payload', () => { pm.expect(customer.phone).to.eql(pm.collectionVariables.get('customerPhone')); });",
                  "pm.collectionVariables.set('customerId', customer.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-partner-key",
                "value": "{{partnerKey}}"
              },
              {
                "key": "x-integration-key",
                "value": "{{integrationKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/{provider}/customers/search?phone={{customerPhone}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "partners",
                "pos",
                "customers",
                "search"
              ],
              "query": [
                {
                  "key": "phone",
                  "value": "{{customerPhone}}"
                }
              ]
            },
            "description": "Verify the first valid sale resulted in customer resolution or creation by phone."
          }
        },
        {
          "name": "Get Customer Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('details returns 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "const customer = body.customer;",
                  "pm.test('correct customer returned', function () { pm.expect(String(customer.id)).to.eql(String(pm.collectionVariables.get('customerId'))); });",
                  "pm.test('points are present', function () { pm.expect(Number(customer.points)).to.be.at.least(Number(pm.collectionVariables.get('minimumPointsBalance'))); });",
                  "pm.test('lifetime points are present', function () { pm.expect(Number(customer.lifetimePoints)).to.be.at.least(Number(pm.collectionVariables.get('minimumPointsBalance'))); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-partner-key",
                "value": "{{partnerKey}}"
              },
              {
                "key": "x-integration-key",
