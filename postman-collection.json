        {
          "name": "Rebind Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('rebind succeeds after disconnect', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('restaurant binding changed', function () { pm.expect(body.restaurantId).to.eql(pm.collectionVariables.get('rebindRestaurantId')); });",
                  "pm.test('token is returned on rebind success', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
