    {
      "name": "Customer API",
      "item": [
        {
          "name": "Search Customer After Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"customer search succeeds\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test(\"response contains customer data\", () => {",
                  "  pm.expect(body).to.be.an(\"object\");",
                  "});",
                  "const customers = Array.isArray(body.data) ? body.data : Array.isArray(body.customers) ? body.customers : Array.isArray(body.results) ? body.results : [];",
                  "pm.test('customer exists', function () { pm.expect(customers.length).to.be.greaterThan(0); });",
                  "const phone = pm.collectionVariables.get('customerPhone');",
                  "const storeId = pm.collectionVariables.get('storeId');",
                  "const matchedCustomer = customers.find((customer) => [customer.phone, customer.normalizedPhone, customer.normalized_phone].includes(phone)) || customers[0];",
                  "pm.test('phone matches sale payload', function () {",
                  "  const identifiers = [matchedCustomer.phone, matchedCustomer.normalizedPhone, matchedCustomer.normalized_phone];",
                  "  pm.expect(identifiers.includes(phone)).to.eql(true);",
                  "});",
                  "const ownerId = matchedCustomer.storeId || matchedCustomer.store_id || matchedCustomer.businessId || matchedCustomer.business_id || (matchedCustomer.store && matchedCustomer.store.id) || (matchedCustomer.business && matchedCustomer.business.id);",
                  "pm.test('customer belongs to expected store/business', function () { pm.expect(ownerId).to.eql(storeId); });",
                  "pm.collectionVariables.set('customerId', matchedCustomer.id || matchedCustomer._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-partner-key",
                "value": "{{partnerKey}}"
              },
              {
                "key": "x-integration-key",
                "value": "{{integrationKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/search?phone={{customerPhone}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "partners",
                "restrox",
                "customers",
                "search"
              ],
              "query": [
                {
                  "key": "phone",
                  "value": "{{customerPhone}}"
                }
              ]
            },
            "description": "Verify the first valid sale resulted in customer resolution or creation by phone."
          }
        },
        {
          "name": "Get Customer Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('details returns 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "const customer = body.data || body.customer || body.result;",
                  "pm.test('correct customer returned', function () { pm.expect(String(customer.id || customer._id)).to.eql(String(pm.collectionVariables.get('customerId'))); });",
                  "const pointsBalance = customer.pointsBalance !== undefined ? customer.pointsBalance : customer.points_balance !== undefined ? customer.points_balance : customer.loyaltySummary && customer.loyaltySummary.pointsBalance !== undefined ? customer.loyaltySummary.pointsBalance : customer.loyalty && customer.loyalty.pointsBalance !== undefined ? customer.loyalty.pointsBalance : customer.loyalty && customer.loyalty.points_balance !== undefined ? customer.loyalty.points_balance : undefined;",
                  "const lifetimePoints = customer.lifetimePointsEarned !== undefined ? customer.lifetimePointsEarned : customer.lifetime_points_earned !== undefined ? customer.lifetime_points_earned : customer.loyaltySummary && customer.loyaltySummary.lifetimePointsEarned !== undefined ? customer.loyaltySummary.lifetimePointsEarned : customer.loyalty && customer.loyalty.lifetimePointsEarned !== undefined ? customer.loyalty.lifetimePointsEarned : undefined;",
                  "pm.test('loyalty data populated', function () { pm.expect(pointsBalance !== undefined || lifetimePoints !== undefined || customer.loyaltySummary || customer.loyalty).to.eql(true); });",
                  "pm.test('points reflect sale processing', function () { pm.expect(Number(pointsBalance !== undefined ? pointsBalance : lifetimePoints !== undefined ? lifetimePoints : 0)).to.be.at.least(Number(pm.collectionVariables.get('minimumPointsBalance'))); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
