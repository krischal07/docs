{
  "info": {
    "name": "Samparka RestroX Native Integration",
    "_postman_id": "c7f3f5e7-7c6e-4b7d-b1b6-restrox-native",
    "description": "RestroX native onboarding, read-only partner customer retrieval, and webhook delivery reference collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://your-domain" },
    { "key": "partnerKey", "value": "replace-with-partner-key" },
    { "key": "integrationKey", "value": "SPK-RX-ABC12345" },
    { "key": "customerId", "value": "replace-with-customer-id" },
    { "key": "token", "value": "replace-with-valid-token" },
    { "key": "invalidToken", "value": "invalid-token" }
  ],
  "item": [
    {
      "name": "Native Partner Flow",
      "item": [
        {
          "name": "Connect Merchant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"account\": {\n    \"id\": \"restrox-account-001\",\n    \"name\": \"Java Express\"\n  },\n  \"locations\": [\n    {\n      \"restaurantId\": \"12345\",\n      \"restaurantName\": \"Kathmandu Branch\",\n      \"outletId\": \"685000000000000000000001\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/connect",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "connect"]
            },
            "description": "Business purpose: connect a merchant using the Samparka Connection Key."
          }
        },
        {
          "name": "Sync Locations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"account\": {\n    \"id\": \"restrox-account-001\",\n    \"name\": \"Java Express\"\n  },\n  \"locations\": [\n    {\n      \"restaurantId\": \"12345\",\n      \"restaurantName\": \"Kathmandu Branch\",\n      \"outletId\": \"685000000000000000000001\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/sync-locations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "sync-locations"]
            },
            "description": "Business purpose: establish RestroX location mappings and detect review issues."
          }
        },
        {
          "name": "Sync Store-Level Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"account\": {\n    \"id\": \"restrox-account-001\",\n    \"name\": \"SPD\"\n  },\n  \"locations\": [\n    {\n      \"restaurantId\": \"12345\",\n      \"restaurantName\": \"SPD\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/sync-locations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "sync-locations"]
            },
            "description": "Business purpose: synchronize a zero-outlet merchant using store-level mapping without outletId."
          }
        },
        {
          "name": "Test Sale",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"restaurantId\": \"12345\",\n  \"payload\": {\n    \"event_type\": \"order.completed\",\n    \"order_id\": \"restrox-sale-1001\",\n    \"created_at\": \"2026-06-08T10:15:00.000Z\",\n    \"amount\": 850,\n    \"currency\": \"NPR\",\n    \"customer\": {\n      \"phone\": \"9801234567\"\n    },\n    \"restaurantId\": \"12345\",\n    \"restaurantName\": \"Kathmandu Branch\",\n    \"items\": [\n      {\n        \"name\": \"Cappuccino\",\n        \"qty\": 1,\n        \"price\": 850\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/test-sale",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "test-sale"]
            },
            "description": "Business purpose: submit a test sale that validates mapped location behavior and production-like loyalty processing."
          }
        }
      ]
    },
    {
      "name": "Customer APIs",
      "item": [
        {
          "name": "Search Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/search?phone=9801234567",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "search"],
              "query": [
                { "key": "phone", "value": "9801234567" }
              ]
            },
            "description": "Business purpose: search for a Samparka-owned customer by exact phone within the merchant store."
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "{{customerId}}"]
            },
            "description": "Business purpose: retrieve one Samparka-owned customer by ID."
          }
        }
      ]
    },
    {
      "name": "Webhook Delivery",
      "item": [
        {
          "name": "Sale Completed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"order.completed\",\n  \"order_id\": \"restrox-sale-1001\",\n  \"created_at\": \"2026-06-08T10:15:00.000Z\",\n  \"amount\": 850,\n  \"currency\": \"NPR\",\n  \"customer\": {\n    \"phone\": \"9800000101\"\n  },\n  \"restaurantId\": \"12345\",\n  \"restaurantName\": \"Kathmandu Branch\",\n  \"items\": [\n    {\n      \"name\": \"Cappuccino\",\n      \"qty\": 1,\n      \"price\": 850\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/restrox/{{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "restrox", "{{token}}"]
            }
          }
        },
        {
