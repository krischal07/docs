      "name": "Merchant API",
      "item": [
        {
          "name": "Create Integration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test('ownership mode is outlet owned', function () { pm.expect(body.data.ownershipMode).to.eql('OUTLET_OWNED'); });",
                  "pm.test('status is CREATED after create', function () { pm.expect(body.data.connectionStatus).to.eql('CREATED'); });",
                  "pm.test('integration key exists', function () { pm.expect(body.data.integrationKey).to.be.a('string').and.not.empty; });",
                  "pm.test('webhook url exists', function () { pm.expect(body.data.webhookUrl).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('integrationId', body.data.id);",
                  "pm.collectionVariables.set('integrationKey', body.data.integrationKey);",
                  "pm.collectionVariables.set('token', body.data.webhookUrl.split('/').pop());",
                  "pm.collectionVariables.set('createdIntegrationKey', body.data.integrationKey);",
                  "pm.collectionVariables.set('createdWebhookToken', body.data.webhookUrl.split('/').pop());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"restrox\",\n  \"storeId\": \"{{storeId}}\",\n  \"outletId\": \"{{outletId}}\"\n}"
