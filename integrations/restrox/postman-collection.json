{
  "info": {
    "name": "Samparka RestroX Partner Guide",
    "_postman_id": "4d6d2f90-7f4c-4eb2-a3e2-2f1d61dcb001",
    "description": "Partner testing collection for RestroX connect and webhook delivery into Samparka. Source fixtures for request and response examples: docs/restrox-partner-guide/examples/payloads.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://your-domain"
    },
    {
      "key": "partnerKey",
      "value": "replace-with-valid-partner-key"
    },
    {
      "key": "integrationKey",
      "value": "replace-with-valid-integration-key"
    },
    {
      "key": "expectedRestaurantId",
      "value": "ktm-branch-01"
    },
    {
      "key": "expectedRestaurantName",
      "value": "Kathmandu Branch"
    },
    {
      "key": "token",
      "value": "replace-with-valid-token"
    },
    {
      "key": "invalidToken",
      "value": "invalid-token"
    }
  ],
  "item": [
    {
      "name": "Connect Restaurant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-partner-key",
            "value": "{{partnerKey}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"restaurantId\": \"{{expectedRestaurantId}}\",\n  \"restaurantName\": \"{{expectedRestaurantName}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/partners/restrox/connect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "partners",
            "restrox",
            "connect"
          ]
        },
        "description": "Business purpose: bind one RestroX restaurant to one outlet-owned Samparka integration.\nLinked documentation pages: docs/restrox-partner-guide/quick-start.md and docs/restrox-partner-guide/testing-guide.md\nSource fixture: examples/payloads.json#/connect_request"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is CONNECTED\", function () {",
              "  pm.expect(pm.response.json().status).to.eql(\"CONNECTED\");",
              "});",
              "",
              "pm.test(\"Restaurant binding persisted\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.externalLocationId).to.eql(pm.environment.get(\"expectedRestaurantId\"));",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Reject Legacy Connect Payload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-partner-key",
            "value": "{{partnerKey}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"locations\": [\n    {\n      \"restaurantId\": \"{{expectedRestaurantId}}\",\n      \"restaurantName\": \"{{expectedRestaurantName}}\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/partners/restrox/connect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "partners",
            "restrox",
            "connect"
          ]
        },
        "description": "Business purpose: prove the legacy account + locations[] payload is intentionally rejected.\nSource fixture: examples/payloads.json#/legacy_connect_request"
      },
      "response": []
    },
