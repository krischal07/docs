{
  "info": {
    "name": "Samparka RestroX Native Integration",
    "_postman_id": "c7f3f5e7-7c6e-4b7d-b1b6-restrox-native",
    "description": "RestroX native onboarding, partner customer APIs, and webhook delivery reference collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://your-domain" },
    { "key": "partnerKey", "value": "replace-with-partner-key" },
    { "key": "integrationKey", "value": "SPK-RX-ABC12345" },
    { "key": "customerId", "value": "replace-with-customer-id" },
    { "key": "token", "value": "replace-with-valid-token" },
    { "key": "invalidToken", "value": "invalid-token" }
  ],
  "item": [
    {
      "name": "Native Partner Flow",
      "item": [
        {
          "name": "Connect Merchant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"account\": {\n    \"id\": \"restrox-account-001\",\n    \"name\": \"Java Express\"\n  },\n  \"locations\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/connect",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "connect"]
            },
            "description": "Business purpose: connect a merchant using the Samparka Connection Key."
          }
        },
        {
          "name": "Sync Locations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"account\": {\n    \"id\": \"restrox-account-001\",\n    \"name\": \"Java Express\"\n  },\n  \"locations\": [\n    {\n      \"externalLocationId\": \"ktm-branch-01\",\n      \"externalLocationName\": \"Kathmandu Branch\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/sync-locations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "sync-locations"]
            },
            "description": "Business purpose: synchronize RestroX locations and detect review issues."
          }
        },
        {
          "name": "Test Sale",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"integrationKey\": \"{{integrationKey}}\",\n  \"payload\": {\n    \"event_type\": \"order.completed\",\n    \"order_id\": \"restrox-sale-1001\",\n    \"created_at\": \"2026-06-08T10:15:00.000Z\",\n    \"amount\": 850,\n    \"currency\": \"NPR\",\n    \"customer\": {\n      \"phone\": \"9801234567\"\n    },\n    \"external_location_id\": \"ktm-branch-01\",\n    \"external_location_name\": \"Kathmandu Branch\",\n    \"items\": [\n      {\n        \"name\": \"Cappuccino\",\n        \"qty\": 1,\n        \"price\": 850\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/test-sale",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "test-sale"]
            },
            "description": "Business purpose: submit a test sale through the existing event processing pipeline."
          }
        }
      ]
    },
    {
      "name": "Customer APIs",
      "item": [
        {
          "name": "Search Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/search?phone=9801234567",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "search"],
              "query": [
                { "key": "phone", "value": "9801234567" }
              ]
            },
            "description": "Business purpose: search for a customer by exact phone within the merchant store."
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asha\",\n  \"phone\": \"+9779801234567\",\n  \"email\": \"asha@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers"]
            },
            "description": "Business purpose: create a customer or return an existing normalized-phone match."
          }
        },
        {
          "name": "Upsert Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asha\",\n  \"phone\": \"9779801234567\",\n  \"email\": \"asha@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/upsert",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "upsert"]
            },
            "description": "Business purpose: create-or-return-existing by normalized phone identity."
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "{{customerId}}"]
            },
            "description": "Business purpose: fetch one customer by ID."
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-partner-key", "value": "{{partnerKey}}" },
              { "key": "x-integration-key", "value": "{{integrationKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asha Sharma\",\n  \"email\": \"asha.sharma@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/partners/restrox/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "partners", "restrox", "customers", "{{customerId}}"]
            },
            "description": "Business purpose: update the partner-supported customer fields."
          }
        }
      ]
    },
    {
      "name": "Webhook Delivery",
      "item": [
        {
          "name": "Sale Completed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"order.completed\",\n  \"order_id\": \"restrox-sale-1001\",\n  \"created_at\": \"2026-06-08T10:15:00.000Z\",\n  \"amount\": 850,\n  \"currency\": \"NPR\",\n  \"customer\": {\n    \"phone\": \"9800000101\"\n  },\n  \"external_location_id\": \"ktm-branch-01\",\n  \"external_location_name\": \"Kathmandu Branch\",\n  \"items\": [\n    {\n      \"name\": \"Cappuccino\",\n      \"qty\": 1,\n      \"price\": 850\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/restrox/{{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "restrox", "{{token}}"]
            }
          }
        },
        {
          "name": "Refund Created",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"refund.created\",\n  \"order_id\": \"restrox-sale-1001\",\n  \"created_at\": \"2026-06-08T11:30:00.000Z\",\n  \"amount\": 850,\n  \"currency\": \"NPR\",\n  \"customer\": {\n    \"phone\": \"9800000101\"\n  },\n  \"external_location_id\": \"ktm-branch-01\",\n  \"external_location_name\": \"Kathmandu Branch\",\n  \"items\": [\n    {\n      \"name\": \"Cappuccino\",\n      \"qty\": 1,\n      \"price\": 850\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/restrox/{{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "restrox", "{{token}}"]
            }
          }
        },
        {
          "name": "Voided Sale",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"order.voided\",\n  \"order_id\": \"restrox-sale-1002\",\n  \"created_at\": \"2026-06-08T12:00:00.000Z\",\n  \"amount\": 450,\n  \"currency\": \"NPR\",\n  \"customer\": {\n    \"phone\": \"9800000102\"\n  },\n  \"external_location_id\": \"ktm-branch-01\",\n  \"external_location_name\": \"Kathmandu Branch\",\n  \"items\": [\n    {\n      \"name\": \"Americano\",\n      \"qty\": 1,\n      \"price\": 450\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/restrox/{{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "restrox", "{{token}}"]
            }
          }
        },
        {
          "name": "Duplicate Sale",
          "request": {
            "method": "POST",
