                  "pm.test('integration id matches', function () { pm.expect(body.data.id).to.eql(pm.collectionVariables.get('integrationId')); });",
                  "pm.test('status is CREATED before connect', function () { pm.expect(body.data.connectionStatus).to.eql('CREATED'); });",
